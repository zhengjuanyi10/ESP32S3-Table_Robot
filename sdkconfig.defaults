# ESP32-S3-DevKitC-1-N32R16V
# 32 MB Octal flash + 16 MB Octal PSRAM, both at 1.8 V.

# External flash
CONFIG_ESPTOOLPY_OCT_FLASH=y
CONFIG_ESPTOOLPY_FLASHMODE_OPI=y
CONFIG_ESPTOOLPY_FLASH_SAMPLE_MODE_DTR=y
CONFIG_ESPTOOLPY_FLASHFREQ_80M=y
CONFIG_ESPTOOLPY_FLASHSIZE_32MB=y

# External PSRAM
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_SPEED_80M=y
CONFIG_SPIRAM_USE_MALLOC=y
CONFIG_SPIRAM_MALLOC_ALWAYSINTERNAL=16384
CONFIG_SPIRAM_MALLOC_RESERVE_INTERNAL=32768
CONFIG_SPIRAM_MEMTEST=y
CONFIG_TABLE_ROBOT_DISPLAY_GPIO_DELAY_US=0
CONFIG_TABLE_ROBOT_DISPLAY_SCLK_GPIO=4
CONFIG_TABLE_ROBOT_DISPLAY_MOSI_GPIO=5
CONFIG_TABLE_ROBOT_DISPLAY_CS_GPIO=6
CONFIG_TABLE_ROBOT_DISPLAY_DC_GPIO=7
CONFIG_TABLE_ROBOT_DISPLAY_RESET_GPIO=10
CONFIG_TABLE_ROBOT_DISPLAY_BACKLIGHT_GPIO=11
CONFIG_TABLE_ROBOT_DISPLAY_BRIGHTNESS_PERCENT=40

# Capacitive touch (direct to GPIO8/GPIO9, GPIO12 RST, GPIO13 INT)
CONFIG_TABLE_ROBOT_TOUCH_ENABLE=y
CONFIG_TABLE_ROBOT_TOUCH_BYPASS_TCA=y
CONFIG_TABLE_ROBOT_TOUCH_TCA_CHANNEL=1
CONFIG_TABLE_ROBOT_TOUCH_TCA_ADDR=0x70
CONFIG_TABLE_ROBOT_TOUCH_RESET_GPIO=12
CONFIG_TABLE_ROBOT_TOUCH_INT_GPIO=13
CONFIG_TABLE_ROBOT_TOUCH_I2C_FREQ_HZ=50000
CONFIG_TABLE_ROBOT_TOUCH_FT6X36_ADDR=0x38
CONFIG_TABLE_ROBOT_TOUCH_GT911_ADDR_PRIMARY=0x5D
CONFIG_TABLE_ROBOT_TOUCH_GT911_ADDR_SECONDARY=0x14
CONFIG_TABLE_ROBOT_TOUCH_CST816_ADDR=0x15
# Touch reports in portrait natively — no swap or invert needed.
CONFIG_TABLE_ROBOT_TOUCH_SWAP_XY=n
CONFIG_TABLE_ROBOT_TOUCH_INVERT_X=n
CONFIG_TABLE_ROBOT_TOUCH_INVERT_Y=n
CONFIG_TABLE_ROBOT_TOUCH_POLL_PERIOD_MS=50
