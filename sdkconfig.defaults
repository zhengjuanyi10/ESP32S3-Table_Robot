# ESP32-S3-DevKitC-1-N32R16V
# 32 MB Octal flash + 16 MB Octal PSRAM, both at 1.8 V.

# External flash
CONFIG_ESPTOOLPY_OCT_FLASH=y
CONFIG_ESPTOOLPY_FLASHMODE_OPI=y
CONFIG_ESPTOOLPY_FLASH_SAMPLE_MODE_DTR=y
CONFIG_ESPTOOLPY_FLASHFREQ_80M=y
CONFIG_ESPTOOLPY_FLASHSIZE_32MB=y

# External PSRAM
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_SPEED_80M=y
CONFIG_SPIRAM_USE_MALLOC=y
CONFIG_SPIRAM_MALLOC_ALWAYSINTERNAL=16384
CONFIG_SPIRAM_MALLOC_RESERVE_INTERNAL=32768
CONFIG_SPIRAM_MEMTEST=y
CONFIG_TABLE_ROBOT_DISPLAY_GPIO_DELAY_US=0
CONFIG_TABLE_ROBOT_DISPLAY_SCLK_GPIO=4
CONFIG_TABLE_ROBOT_DISPLAY_MOSI_GPIO=5
CONFIG_TABLE_ROBOT_DISPLAY_CS_GPIO=6
CONFIG_TABLE_ROBOT_DISPLAY_DC_GPIO=7
CONFIG_TABLE_ROBOT_DISPLAY_RESET_GPIO=10
CONFIG_TABLE_ROBOT_DISPLAY_BACKLIGHT_GPIO=11
CONFIG_TABLE_ROBOT_DISPLAY_BRIGHTNESS_PERCENT=40
CONFIG_TABLE_ROBOT_TOUCH_RESET_GPIO=12
CONFIG_TABLE_ROBOT_TOUCH_INT_GPIO=13
